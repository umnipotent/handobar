{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HandoBar",
  "mainBinaryName": "handobar",
  "version": "0.2.2",
  "identifier": "dev.qus0in.handobar",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HandoBar",
        "width": 800,
        "minWidth": 408,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "handobar-dev"
    }
  }
}
